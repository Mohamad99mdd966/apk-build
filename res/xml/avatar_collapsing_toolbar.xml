<?xml version="1.0" encoding="utf-8"?>
<MotionScene
  xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:motion="http://schemas.android.com/apk/res-auto">
    <Transition motion:constraintSetEnd="@id/collapsed" motion:constraintSetStart="@id/expanded" motion:duration="100">
        <OnSwipe motion:dragDirection="dragUp" motion:touchAnchorId="@id/tabViewPager" motion:touchAnchorSide="top" />
    </Transition>
    <ConstraintSet android:id="@id/expanded">
        <Constraint android:layout_gravity="center_horizontal" android:id="@id/avatarImage" android:layout_width="@dimen/avatar_max_size" android:layout_height="@dimen/avatar_max_size" motion:layout_constraintEnd_toEndOf="parent" motion:layout_constraintStart_toStartOf="parent" motion:layout_constraintTop_toBottomOf="@id/backButton" />
        <Constraint android:id="@id/avatarLoadingProgressBar">
            <PropertySet motion:visibilityMode="ignore" />
        </Constraint>
        <Constraint android:id="@id/errorIcon">
            <PropertySet motion:visibilityMode="ignore" />
        </Constraint>
        <Constraint android:id="@id/errorRetry">
            <PropertySet motion:visibilityMode="ignore" />
        </Constraint>
        <Constraint android:id="@id/errorText">
            <PropertySet motion:visibilityMode="ignore" />
        </Constraint>
        <Constraint android:id="@id/avatarErrorBackground">
            <PropertySet motion:visibilityMode="ignore" />
        </Constraint>
    </ConstraintSet>
    <ConstraintSet android:id="@id/collapsed" motion:deriveConstraintsFrom="@id/expanded">
        <Constraint android:layout_gravity="center_horizontal" android:id="@id/avatarImage" android:layout_width="@dimen/avatar_appbar_min_size" android:layout_height="@dimen/avatar_appbar_min_size" motion:layout_constraintEnd_toEndOf="parent" motion:layout_constraintStart_toStartOf="parent" motion:layout_constraintTop_toBottomOf="@id/backButton" />
    </ConstraintSet>
</MotionScene>